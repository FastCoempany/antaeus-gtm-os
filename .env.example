# Antaeus GTM OS — local environment variables template.
#
# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored; never commit real credentials.
#
# For production deploys, these are set via Cloudflare Pages build env (and
# via GitHub Actions secrets for build-time needs).
#
# Only variables prefixed with VITE_ are exposed to client-side code. Anything
# server-side (if introduced later) uses a different prefix and must not be
# read from import.meta.env.

# --- Observability (Phase 1.4) ---

# Sentry project DSN. Obtain from: Sentry dashboard → Settings → Projects → Antaeus → Client Keys (DSN).
# Leave blank locally to skip Sentry init (Sentry is off by default in dev).
VITE_SENTRY_DSN=

# Environment tag attached to every Sentry event. Set to "development" locally,
# "staging" on preview deploys, "production" on main branch deploys.
VITE_SENTRY_ENV=development

# Posthog project API key. Obtain from: Posthog → Project Settings → Project API Key.
# Leave blank locally to skip Posthog init.
VITE_POSTHOG_API_KEY=

# Posthog ingest host. Use https://us.i.posthog.com for US project, or https://eu.i.posthog.com for EU.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Release tag attached to Sentry events (optional). Usually the short git SHA.
# Automatically set in CI via the build pipeline; leave blank for local dev.
VITE_APP_RELEASE=

# --- Supabase (Phase 2 — not yet used) ---

# Supabase project URL. Obtain from: Supabase dashboard → Project Settings → API → Project URL.
VITE_SUPABASE_URL=

# Supabase anon (public) key. Safe to include in client bundle; row-level-security
# policies enforce per-user data isolation at the database layer.
VITE_SUPABASE_ANON_KEY=
