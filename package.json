{
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:cloudflare && playwright test",
    "test:e2e:headed": "npm run build:cloudflare && playwright test --headed",
    "test:realtime": "npm run build:cloudflare && playwright test --grep @realtime --pass-with-no-tests",
    "build:cloudflare": "node tools/deploy/build-cloudflare-assets.js",
    "deploy:cloudflare": "npm run build:cloudflare && npx wrangler versions upload",
    "voice:check": "vitest run src/lib/voice",
    "ds:check": "vitest run src/lib/voice src/lib/design-system src/icons"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260515.1",
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "puppeteer": "^24.42.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.0"
  },
  "dependencies": {
    "@preact/signals": "^2.4.0",
    "@sentry/browser": "^10.50.0",
    "@supabase/supabase-js": "^2.50.0",
    "posthog-js": "^1.371.2",
    "preact": "^10.29.1"
  },
  "antaeusDesignSystem": "1.9.0"
}
