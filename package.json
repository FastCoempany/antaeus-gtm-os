  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "puppeteer": "^24.42.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.0"
  },
  "dependencies": {
    "preact": "^10.29.1"
  }
}
